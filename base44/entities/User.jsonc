{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "member",
        "guest"
      ],
      "default": "guest",
      "description": "User role - admin for church staff, member for approved congregants, guest for pending/unapproved users"
    },
    "phone": {
      "type": "string"
    },
    "member_since": {
      "type": "string",
      "format": "date"
    }
  },
  "required": []
}